# ── Public IP ─────────────────────────────────────────
request_public_ip=$(grep -m1 -oE '^[0-9]{1,3}(\.[0-9]{1,3}){3}$' \
  <<<"$(wget -T10 -t1 -4qO- "http://ip1.dynupdate.no-ip.com/" 2>/dev/null \
     || curl -m10 -4Ls "http://ip1.dynupdate.no-ip.com/" 2>/dev/null)")

# ── Compat helpers ────────────────────────────────────
# uptime -p not available on Ubuntu 14/16 — fallback
_uptime() {
  uptime -p 2>/dev/null | sed 's/up //' \
    || awk '{d=int($1/86400);h=int(($1%86400)/3600);m=int(($1%3600)/60);
             printf "%dd %dh %dm",d,h,m}' /proc/uptime
}

# nproc fallback
_nproc() {
  nproc 2>/dev/null || grep -c '^processor' /proc/cpuinfo
}

# ss fallback to netstat
_listening_ports() {
  if command -v ss &>/dev/null; then
    ss -tlunp 2>/dev/null
  else
    netstat -tlunp 2>/dev/null
  fi
}

# curl/wget fallback for ipinfo
_fetch() {
  curl -s --max-time 5 "$1" 2>/dev/null \
    || wget -qO- --timeout=5 "$1" 2>/dev/null \
    || echo "N/A"
}

