# ══════════════════════════════════════════════════════
#  TWEAK UDP SPEED
# ══════════════════════════════════════════════════════
tweak_udp_speed() {
  clear; msg -bar
  print_center -ama " ⚡  TWEAK UDP SPEED"
  msg -bar2
  print_center -verm2 "⚠  WARNING: This may or may not work depending on your OS image"
  msg -bar3
  echo -e "  \033[0;33mApplying kernel network tweaks...\033[0m"
  sleep 1

  echo 0 > /proc/sys/net/ipv4/tcp_timestamps
  echo 4194304 > /proc/sys/net/core/wmem_max
  echo 4194304 > /proc/sys/net/core/rmem_max
  echo "16384 87380 16777216" > /proc/sys/net/ipv4/tcp_wmem
  echo "16384 87380 16777216" > /proc/sys/net/ipv4/tcp_rmem
  echo 4096 > /proc/sys/net/ipv4/tcp_max_syn_backlog
  ulimit -n 65535
  sudo systemctl restart NetworkManager &>/dev/null

  sleep 1
  print_center -verd "✔ Network tweaks applied"
  msg -bar0
  sleep 3
}

# ══════════════════════════════════════════════════════
#  UNINSTALL
# ══════════════════════════════════════════════════════
uninstall_udp_manager() {
  clear; msg -bar
  print_center -ama " ⚠️   UNINSTALL UDP MANAGER"
  msg -bar2
  print_center -verm2 "This will remove UDP Custom and all its binaries."
  msg -bar3
  read -rp "  $(echo -e '\033[1;33mConfirm uninstall? [y/N]: \033[0m')" UNINS
  [[ $UNINS != @(Y|y) ]] && return

  systemctl stop udp-custom udpgw &>/dev/null
  systemctl disable udp-custom udpgw &>/dev/null
  rm -rf /etc/systemd/system/udp-custom.service
  rm -rf /etc/systemd/system/udpgw.service
  rm -rf /root/udp/udp-custom
  rm -rf /root/udp/config.json
  rm -rf /etc/UDPCustom/udp-custom
  rm -rf /usr/bin/udpgw
  systemctl daemon-reload &>/dev/null
  del 1
  print_center -verd "✔  Uninstallation complete"
  rm -rf /usr/bin/udp
  enter; exit
}

