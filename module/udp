    printf "  \033[1;97m%-10s\033[0m \033[0;36m%-10s\033[0m \033[0;37m%-15s\033[0m \033[1;32m%s\033[0m\n",
      port, $1, $7, "LISTEN"
  }' | head -30
  msg -bar3

  local udp_port=""
  [[ -f /root/udp/config.json ]] \
    && udp_port=$(grep '"listen"' /root/udp/config.json | grep -oE '[0-9]+')

  echo -e "\n  \033[1;36m── UDP Custom Status ─────────────────────────\033[0m"
  echo -e "  \033[1;37mUDP Custom Port  : \033[1;32m${udp_port:-Not configured}\033[0m"
