  msg -bar0; enter
}

# ══════════════════════════════════════════════════════
#  BACKUP & RESTORE
# ══════════════════════════════════════════════════════
backup_restore() {
  local bk_dir="/etc/UDPCustom/backups"
  mkdir -p "$bk_dir"

  do_backup() {
    local ts; ts=$(date '+%Y%m%d_%H%M%S')
    local bk_file="${bk_dir}/udp_backup_${ts}.tar.gz"
    tar -czf "$bk_file" /root/udp/config.json /etc/UDPCustom/ \
      /etc/systemd/system/udp-custom.service \
      /etc/systemd/system/udpgw.service 2>/dev/null
    if [[ -f "$bk_file" ]]; then
      print_center -verd "✔  Backup saved: udp_backup_${ts}.tar.gz"
    else
      print_center -verm2 "✗  Backup failed"
    fi
    enter
  }

  do_restore() {
    clear; msg -bar
    print_center -ama " 📦  RESTORE BACKUP"
    msg -bar2
    local backups=( "$bk_dir"/*.tar.gz )
    if [[ ! -f ${backups[0]} ]]; then
      print_center -verm2 "No backups found"; msg -bar0; sleep 2; return
    fi
    local i=1
    for f in "${backups[@]}"; do
      echo -e "  \033[1;36m[$i]\033[0m \033[1;97m$(basename "$f")\033[0m"
      let i++
    done
    back
    read -p "  ⇢  Select backup: " sel
    [[ $sel == "0" ]] && return
    local chosen="${backups[$((sel-1))]}"
    if [[ ! -f "$chosen" ]]; then
      print_center -verm2 "✗ Invalid selection"; sleep 2; return
    fi
    tar -xzf "$chosen" -C / &>/dev/null
    systemctl daemon-reload &>/dev/null
    systemctl restart udp-custom &>/dev/null
    print_center -verd "✔  Restored from $(basename "$chosen")"
    enter
  }

  list_backups() {
    clear; msg -bar
    print_center -ama " 📁  BACKUP LIST"
    msg -bar2
    local backups=( "$bk_dir"/*.tar.gz )
    if [[ ! -f ${backups[0]} ]]; then
      print_center -verm2 "No backups found"
    else
      for f in "${backups[@]}"; do
        local sz; sz=$(du -sh "$f" 2>/dev/null | cut -f1)
        echo -e "  \033[1;36m▸\033[0m \033[1;97m$(basename "$f")\033[0m  \033[0;33m[$sz]\033[0m"
      done
    fi
    msg -bar0; enter
  }

  clear; msg -bar
  print_center -ama " 📦  BACKUP & RESTORE"
  msg -bar2
  echo -e "  \033[1;36m[1]\033[0m \033[1;31m▸\033[0m \033[1;97mCreate Backup\033[0m"
  echo -e "  \033[1;36m[2]\033[0m \033[1;31m▸\033[0m \033[1;97mRestore Backup\033[0m"
  echo -e "  \033[1;36m[3]\033[0m \033[1;31m▸\033[0m \033[1;97mList Backups\033[0m"
  back
  read -p "  ⇢  Selection: " option
  case $option in
  1) do_backup ;;
  2) do_restore ;;
  3) list_backups ;;
  0) return ;;
  esac
}

# ══════════════════════════════════════════════════════
#  VPS INFORMATION
# ══════════════════════════════════════════════════════
vps_info() {
  clear; msg -bar
  lonyidev_banner
  msg -bar2
  print_center -ama " 🖥️   VPS INFORMATION"
  msg -bar2

  local system os_arch ip region isp timezone kernel uptime cpu _core ram disk

  system=$(cat /etc/issue.net 2>/dev/null | head -1 | awk '{print $1,$2}')
  [[ -z "$system" ]] && system=$(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2 | cut -c1-20)
  os_arch=$(uname -m)
  ip=$(_fetch ipinfo.io/ip)
  region=$(_fetch ipinfo.io/region)
  isp=$(_fetch ipinfo.io/org)
  timezone=$(_fetch ipinfo.io/timezone)
  [[ "$timezone" == "N/A" ]] && timezone=$(cat /etc/timezone 2>/dev/null || echo "N/A")
  kernel=$(uname -r)
  uptime=$(_uptime)
  cpu=$(top -bn1 | awk '/Cpu/ { printf "%.1f%%", 100-$8 }' 2>/dev/null || echo "N/A")
  _core=$(_nproc)
  ram=$(free -m | awk 'NR==2{printf "%.1f%% (%sMB / %sMB)", $3*100/$2, $3, $2}')
  disk=$(df -h / | awk 'NR==2{printf "%s used / %s total (%s)", $3, $2, $5}')

  echo ""
  echo -e "\033[1;36m  ┌─────────────────────────────────────────────┐"
  echo -e "  │  \033[1;33m System Information                          \033[1;36m│"
  echo -e "  ├─────────────────────────────────────────────┤"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "OS"       "${system:-Unknown}"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "Arch"     "$os_arch"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "Kernel"   "$kernel"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "Uptime"   "$uptime"
  echo -e "  ├─────────────────────────────────────────────┤"
  echo -e "  │  \033[1;33m Network                                     \033[1;36m│"
  echo -e "  ├─────────────────────────────────────────────┤"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  \033[1;32m%-28s\033[1;36m│\n" "Public IP"  "${ip:-N/A}"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "Region"    "$region"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "ISP"       "${isp:0:28}"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "Timezone"  "$timezone"
  echo -e "  ├─────────────────────────────────────────────┤"
  echo -e "  │  \033[1;33m Resources                                   \033[1;36m│"
  echo -e "  ├─────────────────────────────────────────────┤"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "CPU Usage"   "$cpu"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "CPU Cores"   "$_core"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "RAM Usage"   "${ram:0:28}"
  printf "  │  \033[1;37m%-16s\033[1;36m│\033[0m  %-28s\033[1;36m│\n" "Disk Usage"  "${disk:0:28}"
  echo -e "  ├─────────────────────────────────────────────┤"
  echo -e "  │  \033[1;33m Services                                    \033[1;36m│"
  echo -e "  ├─────────────────────────────────────────────┤"

  for svc in udp-custom udpgw ssh; do
    local state
    systemctl is-active "$svc" &>/dev/null \
      && state="\033[1;32m● Running\033[0m" \
      || state="\033[1;31m● Stopped\033[0m"
    printf "  \033[1;36m│\033[0m  \033[1;37m%-16s\033[1;36m│\033[0m  $(echo -e "$state")%-10s\033[1;36m│\n" "$svc" ""
  done

  echo -e "  └─────────────────────────────────────────────┘\033[0m"
  echo ""
  echo -e "  \033[0;36mDate/Time: $(date '+%A, %d %B %Y — %H:%M:%S')\033[0m"
  msg -bar0
  enter
}

# ══════════════════════════════════════════════════════
#  UDP CUSTOM SERVICE TOGGLE
# ══════════════════════════════════════════════════════
reset_udp_custom() {
  if [[ $(systemctl is-active udp-custom) == 'active' ]]; then
    systemctl stop udp-custom &>/dev/null
    systemctl disable udp-custom &>/dev/null
    print_center -verm2 "● UDP-Custom stopped"
  else
    systemctl start udp-custom &>/dev/null
    if [[ $(systemctl is-active udp-custom) == 'active' ]]; then
      systemctl enable udp-custom &>/dev/null
      print_center -verd "✔ UDP-Custom started"
    else
      print_center -verm2 "✗ Failed to start UDP-Custom"
    fi
  fi
  enter
}

