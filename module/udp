  sleep 1.5
}

# ══════════════════════════════════════════════════════
#  HELPERS  — dropbear PIDs
# ══════════════════════════════════════════════════════
droppids() {
  local port_dropbear log loginsukses pids
  port_dropbear=$(ps aux | grep 'dropbear' | awk 'NR==1{print $17}')
  log=/var/log/auth.log
  loginsukses='Password auth succeeded'
  pids=$(ps ax | grep 'dropbear' | grep " $port_dropbear" | awk '{print $1}')
  for pid in $pids; do
    local pidlogs i=0 pidend login PID user waktu
    pidlogs=$(grep "$pid" "$log" | grep "$loginsukses" | awk '{print $3}')
    for pidend in $pidlogs; do let i++; done
    if [[ -n $pidend ]]; then
      login=$(grep "$pid" "$log" | grep "$pidend" | grep "$loginsukses")
      PID=$pid
      user=$(echo "$login" | awk '{print $10}' | sed -r "s/'/ /g")
      waktu=$(echo "$login" | awk '{print $2"-"$1,$3}')
      while [[ ${#waktu} -lt 13 ]]; do waktu="$waktu "; done
      while [[ ${#user}  -lt 16 ]]; do user="$user ";  done
      while [[ ${#PID}   -lt  8 ]]; do PID="$PID ";   done
      echo "$user $PID $waktu"
    fi
  done
}

show_users() {
  cat /etc/passwd | grep 'home' | grep 'false' \
    | grep -v 'syslog' | grep -v 'hwid' | grep -v 'token' \
    | grep -v '::/' | awk -F ':' '{print $1}'
}

# ══════════════════════════════════════════════════════
#  USER TABLE
# ══════════════════════════════════════════════════════
data_user() {
  local cat_users
  cat_users=$(cat /etc/passwd | grep 'home' | grep 'false' \
    | grep -v 'syslog' | grep -v '::/' | grep -v 'hwid\|token')
  if [[ -z $(echo "$cat_users" | head -1) ]]; then
    print_center -verm2 "  No registered SSH users"; return 1
  fi

  echo -e "\033[1;36m  $(printf '%-13s%-14s%-12s%-6s%-6s%s' \
    'User' 'Password' 'Expires' 'Days' 'Limit' 'Status')\033[0m"
  msg -bar3

  local i=1
  while IFS= read -r line; do
    local u fecha mes_dia ano us pass stat Limit exp EXPTIME
    u=$(echo "$line" | awk -F ':' '{print $1}')
    fecha=$(chage -l "$u" | sed -n '4p' | awk -F ': ' '{print $2}')
    mes_dia=$(echo "$fecha" | awk -F ',' '{print $1}' | sed 's/ //g')
    ano=$(echo "$fecha" | awk -F ', ' '{print $2}' | cut -c3-)
    us=$(printf '%-12s' "$u")
    pass=$(echo "$line" | awk -F ':' '{print $5}' | cut -d',' -f2)
    [[ ${#pass} -gt 12 ]] && pass="••••••"
    pass=$(printf '%-12s' "$pass")

    if [[ $(passwd --status "$u" | cut -d' ' -f2) == "P" ]]; then
      stat="\033[1;32m● UNL\033[0m"
    else
      stat="\033[1;31m● BLK\033[0m"
    fi

    Limit=$(echo "$line" | awk -F ':' '{print $5}' | cut -d',' -f1)
    [[ ${#Limit} -eq 1 ]] && Limit=$(printf '%2s%-4s' "$Limit") || Limit=$(printf '%-6s' "$Limit")

    echo -ne "$(msg -verd "  $i")$(msg -verm2 "─")$(msg -azu "$us") $(msg -azu "$pass")"
    if [[ $(echo "$fecha" | awk '{print $2}') == "" ]]; then
      echo -e " \033[1;31m[No Expiry]\033[0m  $(msg -ama "$Limit")  $(echo -e "$stat")"
    elif [[ $(date +%s) -gt $(date '+%s' -d "$fecha") ]]; then
      echo -e " \033[1;31m${mes_dia}/${ano}\033[0m  \033[1;31mExpired\033[0m  $(msg -ama "$Limit")  $(echo -e "$stat")"
    else
      EXPTIME=$(( ( $(date '+%s' -d "$fecha") - $(date +%s) ) / 86400 ))
      exp=$(printf '%-5s' "$EXPTIME")
      echo -e " \033[1;33m${mes_dia}/${ano}\033[0m  \033[1;32m${exp}d\033[0m  $(msg -ama "$Limit")  $(echo -e "$stat")"
    fi
    let i++
  done <<< "$cat_users"
}

# ══════════════════════════════════════════════════════
#  USER DETAILS
# ══════════════════════════════════════════════════════
detail_user() {
  clear
  local active_users=('' $(show_users))
  msg -bar
  print_center -ama " 📋  USER DETAILS"
  msg -bar2
  if [[ -z ${active_users[1]} ]]; then
    print_center -verm2 "No registered users"; msg -bar0; sleep 2; return
  fi
  data_user
  msg -bar0
  enter
}

# ══════════════════════════════════════════════════════
#  BLOCK / UNBLOCK USER
# ══════════════════════════════════════════════════════
block_user() {
  clear
  local active_users=('' $(show_users))
  msg -bar
  print_center -ama " 🔒  BLOCK / UNBLOCK USER"
  msg -bar2
  data_user
  back

  print_center -ama "Type username from the list above"
  msg -bar3
  local selection user_del
  while [[ -z $selection ]]; do
    msg -nazu "  Username: " && read selection; del 1
  done
  [[ $selection == "0" ]] && return

  if [[ ! $(echo "$selection" | grep -E '[^0-9]') ]]; then
    user_del="${active_users[$selection]}"
  else
    user_del="$selection"
  fi

  [[ -z $user_del ]] && { msg -verm "✗ Invalid user"; msg -bar0; return 1; }
  [[ ! $(echo "${active_users[@]}" | grep -w "$user_del") ]] && {
    msg -verm "✗ User not found"; msg -bar0; return 1; }

  msg -bar
  echo -ne "  \033[1;37mUser: \033[1;36m$user_del\033[0m  ▸  "
  if [[ $(passwd --status "$user_del" | cut -d' ' -f2) == "P" ]]; then
    pkill -u "$user_del" &>/dev/null
    kill -9 $(droppids | grep -w "$user_del" | awk '{print $2}') &>/dev/null
    usermod -L "$user_del" &>/dev/null
    sleep 1
    echo -e "\033[1;31m● BLOCKED\033[0m"
  else
    usermod -U "$user_del"
    sleep 1
    echo -e "\033[1;32m● UNBLOCKED\033[0m"
  fi
  msg -bar0; sleep 2
}

# ══════════════════════════════════════════════════════
#  RENEW USER
# ══════════════════════════════════════════════════════
renew_user_fun() {
  local valid; valid=$(date '+%C%y-%m-%d' -d "+$2 days")
  if chage -E "$valid" "$1"; then
    print_center -verd "✔  User renewed successfully"
  else
    print_center -verm "✗  Renewal failed"
  fi
}

renew_user() {
  clear
  local active_users=('' $(show_users))
  msg -bar; print_center -ama " 🔄  RENEW USER"; msg -bar2
  data_user; back

  print_center -ama "Select or type username"
  msg -bar3
  local selection useredit
  while [[ -z $selection ]]; do
    msg -nazu "  Username: " && read selection; del 1
  done
  [[ $selection == "0" ]] && return

  if [[ ! $(echo "$selection" | grep -E '[^0-9]') ]]; then
    useredit="${active_users[$selection]}"
  else
    useredit="$selection"
  fi
  [[ -z $useredit ]] && { msg -verm "✗ Invalid user"; sleep 2; return 1; }
  [[ ! $(echo "${active_users[@]}" | grep -w "$useredit") ]] && {
    msg -verm "✗ User not found"; sleep 2; return 1; }

  local userdays
  while true; do
    msg -ne "  New duration for $useredit (days): "; read userdays
    [[ -z "$userdays" ]]             && { err_fun 7; continue; }
    [[ "$userdays" != +([0-9]) ]]   && { err_fun 8; continue; }
    [[ "$userdays" -gt 360 ]]       && { err_fun 9; continue; }
    break
  done
  msg -bar
  renew_user_fun "$useredit" "$userdays"
  msg -bar0; sleep 2
}

# ══════════════════════════════════════════════════════
#  REMOVE USER
# ══════════════════════════════════════════════════════
rm_user() {
  pkill -u "$1"
  kill -9 $(droppids | grep -w "$1" | awk '{print $2}') &>/dev/null
  userdel --force "$1" &>/dev/null
  msj=$?
}

remove_user() {
  clear
  local active_users=('' $(show_users))
  msg -bar; print_center -ama " 🗑️   REMOVE USER"; msg -bar2
  data_user; back

  print_center -ama "Select or type username to remove"
  msg -bar3
  local selection user_del
  while [[ -z $selection ]]; do
    msg -nazu "  Username: " && read selection; tput cuu1 && tput dl1
  done
  [[ $selection == "0" ]] && return

  if [[ ! $(echo "$selection" | grep -E '[^0-9]') ]]; then
    user_del="${active_users[$selection]}"
  else
    user_del="$selection"
  fi
  [[ -z $user_del ]] && { msg -verm "✗ Invalid user"; msg -bar0; return 1; }
  [[ ! $(echo "${active_users[@]}" | grep -w "$user_del") ]] && {
    msg -verm "✗ User not found"; msg -bar0; return 1; }

  echo -e "  \033[1;37mRemoving: \033[1;31m$user_del\033[0m"
  rm_user "$user_del"
  if [[ $msj -eq 0 ]]; then
    print_center -verd "✔  User removed"
  else
    print_center -verm "✗  Removal failed"
  fi
  enter
}

# ══════════════════════════════════════════════════════
#  CREATE USER
# ══════════════════════════════════════════════════════
add_user() {
  [[ $(cat /etc/passwd | grep "$1:" | grep -vi "[a-z]$1" | grep -v "[0-9]$1" >/dev/null) ]] && return 1
  local valid pass osl_v
  valid=$(date '+%C%y-%m-%d' -d "+$3 days")
  osl_v=$(openssl version | awk '{print $2}'); osl_v=${osl_v:0:5}
  if [[ $osl_v == '1.1.1' ]]; then
    pass=$(openssl passwd -6 "$2")
  else
    pass=$(openssl passwd -1 "$2")
  fi
  useradd -M -s /bin/false -e "$valid" -K PASS_MAX_DAYS="$3" -p "$pass" -c "$4,$2" "$1" &>/dev/null
  msj=$?
}

new_user() {
  clear
  local active_users=('' $(show_users))
  msg -bar; print_center -ama " ➕  CREATE USER ACCOUNT"; msg -bar2
  data_user; back

  local nameuser userpass userdays limiteuser

  while true; do
    msg -ne "  Username: "; read nameuser
    nameuser=$(echo "$nameuser" | sed 'y/áÁàÀãÃâÂéÉêÊíÍóÓõÕôÔúÚñÑçÇªº/aAaAaAaAeEeEiIoOoOoOuUnNcCao/')
    nameuser=$(echo "$nameuser" | sed -e 's/[^a-z0-9 -]//ig')
    [[ -z $nameuser ]]                              && { err_fun 1; continue; }
    [[ $nameuser == "0" ]]                          && return
    [[ ${#nameuser} -lt 4 ]]                        && { err_fun 2; continue; }
    [[ ${#nameuser} -gt 12 ]]                       && { err_fun 3; continue; }
    [[ $(echo "${active_users[@]}" | grep -w "$nameuser") ]] && { err_fun 14; continue; }
    break
  done

  while true; do
    msg -ne "  Password: "; read userpass
    userpass=$(echo "$userpass" | sed 'y/áÁàÀãÃâÂéÉêÊíÍóÓõÕôÔúÚñÑçÇªº/aAaAaAaAeEeEiIoOoOoOuUnNcCao/')
    [[ -z $userpass ]]    && { err_fun 4; continue; }
    [[ ${#userpass} -lt 4 ]] && { err_fun 5; continue; }
    [[ ${#userpass} -gt 12 ]] && { err_fun 6; continue; }
    break
  done

  while true; do
    msg -ne "  Duration (days): "; read userdays
    [[ -z "$userdays" ]]           && { err_fun 7; continue; }
    [[ "$userdays" != +([0-9]) ]] && { err_fun 8; continue; }
    [[ "$userdays" -gt 360 ]]     && { err_fun 9; continue; }
    break
  done

  while true; do
    msg -ne "  Connection limit: "; read limiteuser
    [[ -z "$limiteuser" ]]           && { err_fun 11; continue; }
    [[ "$limiteuser" != +([0-9]) ]] && { err_fun 12; continue; }
    [[ "$limiteuser" -gt 999 ]]     && { err_fun 13; continue; }
    break
  done

  add_user "$nameuser" "$userpass" "$userdays" "$limiteuser"
  clear
  msg -bar
  if [[ $msj -eq 0 ]]; then
    print_center -verd " ✔  User Created Successfully"
  else
    print_center -verm2 " ✗  Error — User Not Created"
    enter; return 1
  fi
  msg -bar2
  echo -e "\033[1;36m  ┌─────────────────────────────────────┐"
  echo -e "  │  \033[1;37mServer IP   \033[1;36m│\033[1;32m  $request_public_ip"
  echo -e "\033[1;36m  │  \033[1;37mPort Range  \033[1;36m│\033[1;97m  1–65535"
  echo -e "\033[1;36m  │  \033[1;37mUsername    \033[1;36m│\033[1;97m  $nameuser"
  echo -e "\033[1;36m  │  \033[1;37mPassword    \033[1;36m│\033[1;97m  $userpass"
  echo -e "\033[1;36m  │  \033[1;37mDays        \033[1;36m│\033[1;97m  $userdays"
  echo -e "\033[1;36m  │  \033[1;37mExpires     \033[1;36m│\033[1;33m  $(date '+%d-%b-%Y' -d "+$userdays days")"
  echo -e "\033[1;36m  │  \033[1;37mConn Limit  \033[1;36m│\033[1;97m  $limiteuser"
  echo -e "\033[1;36m  └─────────────────────────────────────┘\033[0m"
  msg -bar0
  enter
}

# ══════════════════════════════════════════════════════
#  MULTI-LOGIN LIMITER
# ══════════════════════════════════════════════════════
limiter() {
  ltr() {
    clear
    msg -bar
    print_center -ama " 🛡️   MULTI-LOGIN LIMITER"
    msg -bar2

    # Stop if already running
    for i in $(atq | awk '{print $1}'); do
      if [[ ! $(at -c "$i" | grep '/etc/limiter.sh') == "" ]]; then
        atrm "$i"
        sed -i '/etc\/limiter.sh/d' /var/spool/cron/crontabs/root
        print_center -verd "✔  Limiter stopped"
        enter; return
      fi
    done

    print_center -ama "Block users when they exceed the max connections"
    msg -bar3

    local option
    while [[ -z $option ]]; do
      msg -nama "  Run limiter every (minutes): "; read option
      if [[ ! $option =~ ^[0-9]+$ ]]; then
        del 1; print_center -verm2 "✗ Numbers only"; sleep 1.5; del 1; unset option; continue
      elif [[ $option -le 0 ]]; then
        del 1; print_center -verm2 "✗ Minimum is 1 minute"; sleep 1.5; del 1; unset option; continue
      fi
      del 1
      echo -e "  \033[1;37mRun limiter every: \033[1;32m${option} minutes\033[0m"
      echo "$option" > "${udp_dir}/limit"
    done

    msg -bar3
    print_center -ama "Auto-unlock blocked users (0 = manual unlock)"
    msg -bar3
    unset option
    while [[ -z $option ]]; do
      msg -nama "  Unblock every (minutes, 0=manual): "; read option
      if [[ ! $option =~ ^[0-9]+$ ]]; then
        tput cuu1 && tput dl1
        print_center -verm2 "✗ Numbers only"; sleep 1.5; tput cuu1 && tput dl1
        unset option; continue
      fi
      tput cuu1 && tput dl1
      [[ $option -le 0 ]] \
        && echo -e "  \033[1;37mUnblock: \033[1;33mManual\033[0m" \
        || echo -e "  \033[1;37mUnblock every: \033[1;32m${option} minutes\033[0m"
      echo "$option" > "${udp_dir}/unlimit"
    done

    nohup "${udp_dir}/limiter.sh" &>/dev/null &
    msg -bar
    print_center -verd "✔  Limiter started"
    enter
  }

  l_exp() {
    clear; msg -bar
    print_center -ama " ⏱️   EXPIRY LIMITER"
    msg -bar2
    local l_cron; l_cron=$(grep -w 'limiter.sh' /var/spool/cron/crontabs/root | grep -w 'ssh')
    if [[ -z "$l_cron" ]]; then
      echo '0 1 * * * /etc/limiter.sh --ssh' >> /var/spool/cron/crontabs/root
      print_center -verd "✔  Expiry limiter scheduled — runs daily at 01:00"
    else
      sed -i '/limiter.sh --ssh/d' /var/spool/cron/crontabs/root
      print_center -verm2 "✗  Expiry limiter stopped"
    fi
    enter; return
  }

  log() {
    clear; msg -bar
    print_center -ama " 📜  LIMITER LOG"
    msg -bar2
    [[ ! -e /etc/limit.log ]] && touch /etc/limit.log
    if [[ -z $(cat /etc/limit.log) ]]; then
      print_center -ama "  No records found"; msg -bar0; sleep 2; return
    fi
    msg -teal "$(cat /etc/limit.log)"
    msg -bar
    print_center -ama "►► Press enter to continue  |  0 to clear ◄◄"
    read option
    [[ $option == "0" ]] && > /etc/limit.log && print_center -verd "✔  Log cleared"
  }

  # ── Kick a specific user's sessions ──
  kick_user() {
    clear; msg -bar
    print_center -ama " ⚡  KICK USER SESSION"
    msg -bar2
    data_user; back
    print_center -ama "Type username to kick all sessions"
    msg -bar3
    local sel
    while [[ -z $sel ]]; do msg -nazu "  Username: " && read sel; del 1; done
    [[ $sel == "0" ]] && return
    pkill -u "$sel" &>/dev/null
    kill -9 $(droppids | grep -w "$sel" | awk '{print $2}') &>/dev/null
    print_center -verd "✔  All sessions for $sel terminated"
    msg -bar0; sleep 2
  }

  local lim_e
  [[ $(grep -w 'limiter.sh' /var/spool/cron/crontabs/root | grep -w 'ssh') ]] \
    && lim_e="\033[1;32m[ON]\033[0m" \
    || lim_e="\033[1;31m[OFF]\033[0m"

  clear; msg -bar
  print_center -ama " 🛡️   ACCOUNT LIMITER"
  msg -bar2
  echo -e "  \033[1;36m[1]\033[0m \033[1;31m▸\033[0m \033[1;97mMulti-Login Limiter\033[0m"
  echo -e "  \033[1;36m[2]\033[0m \033[1;31m▸\033[0m \033[1;97mExpiry Limiter  $lim_e\033[0m"
  echo -e "  \033[1;36m[3]\033[0m \033[1;31m▸\033[0m \033[1;97mLimiter Log\033[0m"
  echo -e "  \033[1;36m[4]\033[0m \033[1;31m▸\033[0m \033[1;31mKick User Sessions\033[0m"
  back
  read -p "  ⇢  Selection: " option
  case $option in
  1) ltr ;;
  2) l_exp ;;
  3) log ;;
  4) kick_user ;;
  0) return ;;
  esac
}

# ══════════════════════════════════════════════════════
#  CUSTOM MESSAGES
# ══════════════════════════════════════════════════════
custom_messages() {
  local msg_dir="/etc/UDPCustom/messages"
  mkdir -p "$msg_dir"

  set_motd() {
    clear; msg -bar
    print_center -ama " 💬  SET MOTD (Message of the Day)"
    msg -bar2
    if [[ -f /etc/motd ]]; then
      echo -e "\033[0;36m  Current MOTD:\033[0m"
      cat /etc/motd
    else
      echo -e "\033[0;33m  No MOTD set.\033[0m"
    fi
    msg -bar3
    echo -e "  \033[1;37mEnter new MOTD (leave blank to clear, 0 to cancel):\033[0m"
    echo -e "  \033[0;36m(Supports multiple lines — type END on a new line to finish)\033[0m"
    msg -bar3
    local line motd_content=""
    while IFS= read -r line; do
      [[ $line == "0" ]] && return
      [[ $line == "END" ]] && break
      motd_content+="$line\n"
    done
    if [[ -z "$motd_content" ]]; then
      > /etc/motd
      print_center -verd "✔  MOTD cleared"
    else
      echo -e "$motd_content" > /etc/motd
      print_center -verd "✔  MOTD updated"
    fi
    enter
  }

  set_ssh_banner() {
    clear; msg -bar
    print_center -ama " 🔖  SET SSH LOGIN BANNER"
    msg -bar2
    if [[ -f /etc/issue.net ]]; then
      echo -e "\033[0;36m  Current Banner:\033[0m"
      cat /etc/issue.net
    fi
    msg -bar3
    echo -e "  \033[1;37mEnter new SSH banner (END to finish, 0 to cancel):\033[0m"
    msg -bar3
    local line banner_content=""
    while IFS= read -r line; do
      [[ $line == "0" ]] && return
      [[ $line == "END" ]] && break
      banner_content+="$line\n"
    done
    if [[ -z "$banner_content" ]]; then
      > /etc/issue.net
      print_center -verd "✔  Banner cleared"
    else
      echo -e "$banner_content" > /etc/issue.net
      # Ensure SSH uses the banner
      if ! grep -q "^Banner" /etc/ssh/sshd_config; then
        echo "Banner /etc/issue.net" >> /etc/ssh/sshd_config
      else
        sed -i 's|^Banner.*|Banner /etc/issue.net|' /etc/ssh/sshd_config
      fi
      systemctl restart ssh &>/dev/null
      print_center -verd "✔  SSH banner updated and SSH restarted"
    fi
    enter
  }

  set_udp_response() {
    clear; msg -bar
    print_center -ama " 📡  SET UDP CUSTOM RESPONSE MESSAGE"
    msg -bar2
    local cfg="/root/udp/config.json"
    if [[ -f "$cfg" ]]; then
      echo -e "\033[0;36m  Current config:\033[0m"
      cat "$cfg"
    fi
    msg -bar3
    echo -e "  \033[1;37mEnter the custom response string (0 to cancel):\033[0m"
    msg -bar3
    local resp
    msg -nazu "  Response: "; read resp
    [[ $resp == "0" ]] && return
    if [[ -f "$cfg" ]]; then
      # Add/update "response" key
      if grep -q '"response"' "$cfg"; then
        sed -i "s|\"response\":.*|\"response\": \"$resp\"|" "$cfg"
      else
        sed -i "s|{|{\n  \"response\": \"$resp\",|" "$cfg"
      fi
      systemctl restart udp-custom &>/dev/null
      print_center -verd "✔  Response message set and service restarted"
    else
      print_center -verm2 "✗  Config file not found"
    fi
    enter
  }

  view_messages() {
    clear; msg -bar
    print_center -ama " 👁️   VIEW CURRENT MESSAGES"
    msg -bar2
    echo -e "\033[1;36m  ── MOTD ──────────────────────────────────\033[0m"
    [[ -f /etc/motd ]] && cat /etc/motd || echo -e "  \033[0;33m(not set)\033[0m"
    echo -e "\033[1;36m  ── SSH Banner ────────────────────────────\033[0m"
    [[ -f /etc/issue.net ]] && cat /etc/issue.net || echo -e "  \033[0;33m(not set)\033[0m"
    msg -bar0
    enter
  }

  clear; msg -bar
  print_center -ama " 💬  CUSTOM MESSAGES"
  msg -bar2
  echo -e "  \033[1;36m[1]\033[0m \033[1;31m▸\033[0m \033[1;97mSet MOTD (Message of the Day)\033[0m"
  echo -e "  \033[1;36m[2]\033[0m \033[1;31m▸\033[0m \033[1;97mSet SSH Login Banner\033[0m"
  echo -e "  \033[1;36m[3]\033[0m \033[1;31m▸\033[0m \033[1;97mSet UDP Custom Response\033[0m"
  echo -e "  \033[1;36m[4]\033[0m \033[1;31m▸\033[0m \033[1;97mView Current Messages\033[0m"
  back
  read -p "  ⇢  Selection: " option
  case $option in
  1) set_motd ;;
  2) set_ssh_banner ;;
  3) set_udp_response ;;
  4) view_messages ;;
  0) return ;;
  esac
}

# ══════════════════════════════════════════════════════
#  CONNECTION MONITOR
# ══════════════════════════════════════════════════════
connection_monitor() {
  clear
  echo -e "\033[1;36m  Press Ctrl+C to exit monitor\033[0m"
  sleep 1
  while true; do
    clear
    msg -bar
    print_center -ama " 📡  LIVE CONNECTION MONITOR"
    msg -bar2
    echo -e "\033[1;33m  $(date '+%Y-%m-%d %H:%M:%S')\033[0m"
    msg -bar3
    printf "\033[1;36m  %-16s %-8s %-20s %s\033[0m\n" "USER" "CONNS" "PROTO" "STATUS"
    msg -bar3

    local cat_users
    cat_users=$(cat /etc/passwd | grep 'home' | grep 'false' \
      | grep -v 'syslog' | grep -v 'hwid' | grep -v 'token' | grep -v '::/' \
      | awk -F ':' '{print $1}')

    local total_conns=0
    while IFS= read -r u; do
      [[ -z $u ]] && continue
      local sqd ovp drop cnx
      sqd=$(ps -u "$u" | grep sshd | wc -l 2>/dev/null || echo 0)
      ovp=0
      [[ -f /etc/openvpn/openvpn-status.log ]] \
        && ovp=$(grep -cE ",$u," /etc/openvpn/openvpn-status.log || echo 0)
      drop=0
      netstat -nltp 2>/dev/null | grep -q 'dropbear' \
        && drop=$(droppids | grep -w "$u" | wc -l)
      cnx=$(( sqd + drop + ovp ))
      total_conns=$(( total_conns + cnx ))

      local status_color="\033[1;32m"
      [[ $cnx -eq 0 ]] && status_color="\033[0;37m"
      [[ $cnx -ge 3 ]] && status_color="\033[1;33m"

      printf "  \033[1;97m%-16s\033[0m ${status_color}%-8s\033[0m \033[0;36m%-20s\033[0m \033[1;32m%s\033[0m\n" \
        "$u" "$cnx" "SSH/UDP" "$(passwd --status "$u" | awk '{print $2}' | grep -q P && echo ACTIVE || echo LOCKED)"
    done <<< "$cat_users"

    msg -bar3
    echo -e "  \033[1;37mTotal Active Connections: \033[1;32m${total_conns}\033[0m"
    msg -bar0
    sleep 5
  done
}

# ══════════════════════════════════════════════════════
#  PORT MANAGER
# ══════════════════════════════════════════════════════
port_manager() {
  clear; msg -bar
  print_center -ama " 🔌  PORT MANAGER"
  msg -bar2
  echo -e "\033[1;33m  ── Listening Ports ──────────────────────────\033[0m"
  echo ""
  printf "\033[1;36m  %-10s %-10s %-15s %s\033[0m\n" "PORT" "PROTO" "SERVICE" "STATE"
  msg -bar3
  _listening_ports | awk 'NR>1 {
    split($5,a,":");
