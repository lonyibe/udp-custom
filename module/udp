# ══════════════════════════════════════════════════════
#  ERROR HANDLER
# ══════════════════════════════════════════════════════
err_fun() {
  del 2
  case $1 in
  1)  print_center -verm2 "✗  Username cannot be empty" ;;
  2)  print_center -verm2 "✗  Username too short (min 4 chars)" ;;
  3)  print_center -verm2 "✗  Username too long (max 12 chars)" ;;
  4)  print_center -verm2 "✗  Password cannot be empty" ;;
  5)  print_center -verm2 "✗  Password too short (min 4 chars)" ;;
  6)  print_center -verm2 "✗  Password too long (max 12 chars)" ;;
  7)  print_center -verm2 "✗  Days field cannot be empty" ;;
  8)  print_center -verm2 "✗  Days must be a number" ;;
