export NEGRITO='\e[1m'
export SEMCOR='\e[0m'

# ── msg() — Colour Printer ────────────────────────────
msg() {
  local COLORS=(
    [0]='\033[1;37m'   # WHITE/BRAN
    [1]='\e[31m'       # RED
    [2]='\e[32m'       # GREEN
    [3]='\e[33m'       # YELLOW
    [4]='\e[34m'       # BLUE
    [5]='\e[91m'       # LIGHT RED
    [6]='\033[1;97m'   # BRIGHT WHITE
    [7]='\e[36m'       # CYAN/TEAL
    [8]='\e[30m'       # BLACK
    [9]='\033[34m'     # BLUE2
  )
  local NEGRITO='\e[1m'
  local SEMCOR='\e[0m'

  case $1 in
  -ne)    echo -ne "${COLORS[1]}${NEGRITO}${2}${SEMCOR}" ;;
  -nazu)  echo -ne "${COLORS[6]}${NEGRITO}${2}${SEMCOR}" ;;
  -nverd) echo -ne "${COLORS[2]}${NEGRITO}${2}${SEMCOR}" ;;
  -nama)  echo -ne "${COLORS[3]}${NEGRITO}${2}${SEMCOR}" ;;
  -ama)   echo -e  "${COLORS[3]}${NEGRITO}${2}${SEMCOR}" ;;
  -verm)  echo -e  "${COLORS[3]}${NEGRITO}[!] ${COLORS[1]}${2}${SEMCOR}" ;;
  -verm2) echo -e  "${COLORS[1]}${NEGRITO}${2}${SEMCOR}" ;;
  -verm3) echo -e  "${COLORS[1]}${2}${SEMCOR}" ;;
  -teal)  echo -e  "${COLORS[7]}${NEGRITO}${2}${SEMCOR}" ;;
  -teal2) echo -e  "${COLORS[7]}${2}${SEMCOR}" ;;
  -blak)  echo -e  "${COLORS[8]}${NEGRITO}${2}${SEMCOR}" ;;
  -blak2) echo -e  "${COLORS[8]}${2}${SEMCOR}" ;;
  -azu)   echo -e  "${COLORS[6]}${NEGRITO}${2}${SEMCOR}" ;;
  -blu)   echo -e  "${COLORS[9]}${NEGRITO}${2}${SEMCOR}" ;;
  -blu1)  echo -e  "${COLORS[9]}${2}${SEMCOR}" ;;
  -verd)  echo -e  "${COLORS[2]}${NEGRITO}${2}${SEMCOR}" ;;
  -bra)   echo -e  "${COLORS[0]}${NEGRITO}${2}${SEMCOR}" ;;
  # ── Borders ──
  -bar)  echo -e "\033[1;36m╔══════════════════════════════════════════════╗${SEMCOR}" ;;
  -bar0) echo -e "\033[1;36m╚══════════════════════════════════════════════╝${SEMCOR}" ;;
  -bar2) echo -e "\033[1;36m╠══════════════════════════════════════════════╣${SEMCOR}" ;;
  -bar3) echo -e "\033[1;36m║──────────────────────────────────────────────║${SEMCOR}" ;;
  -bar4) echo -e "\033[0;36m┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄${SEMCOR}" ;;
  esac
}

# ── print_center() ────────────────────────────────────
print_center() {
  local col text
  if [[ -z $2 ]]; then
    text="$1"
  else
    col="$1"; text="$2"
  fi
  while IFS= read -r line; do
    local stripped
    stripped=$(echo -e "$line" | sed 's/\x1b\[[0-9;]*m//g')
    local x=$(( (46 - ${#stripped}) / 2 ))
    local space=''
    for ((i=0;i<x;i++)); do space+=' '; done
    space+="$line"
    if [[ -z $2 ]]; then
      msg -azu "$space"
    else
      msg "$col" "$space"
    fi
  done <<< "$(echo -e "$text")"
}

